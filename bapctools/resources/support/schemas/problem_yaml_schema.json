{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$defs": {
        "Person": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "object",
                    "properties": {
                        "email": {
                            "type": "string",
                            "description": "The person's email address, such as `jcarberry@brown.edu`"
                        },
                        "kattis": {
                            "type": "string",
                            "description": "The person's username on Kattis, such as `jcarberry01`"
                        },
                        "name": {
                            "type": "string",
                            "description": "The person's name, such as `Josiah Carberry`"
                        },
                        "orcid": {
                            "type": "string",
                            "description": "The person's ID in the Open Researcher and Contributor ID system, such as `0000-0002-1825-0097`"
                        }
                    },
                    "required": [
                        "name"
                    ]
                }
            ]
        },
        "Persons": {
            "anyOf": [
                {
                    "$ref": "#/$defs/Person"
                },
                {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/Person"
                    },
                    "prefixItems": [
                        {
                            "$ref": "#/$defs/Person"
                        }
                    ],
                    "minItems": 1
                }
            ]
        },
        "ProgrammingLanguage": {
            "enum": [
                "ada",
                "algol68",
                "apl",
                "bash",
                "c",
                "cgmp",
                "cobol",
                "cpp",
                "cppgmp",
                "crystal",
                "csharp",
                "d",
                "dart",
                "elixir",
                "erlang",
                "forth",
                "fortran",
                "fsharp",
                "gerbil",
                "go",
                "haskell",
                "java",
                "javaalgs4",
                "javascript",
                "julia",
                "kotlin",
                "lisp",
                "lua",
                "modula2",
                "nim",
                "objectivec",
                "ocaml",
                "octave",
                "odin",
                "pascal",
                "perl",
                "php",
                "prolog",
                "python2",
                "python3",
                "python3numpy",
                "racket",
                "ruby",
                "rust",
                "scala",
                "simula",
                "smalltalk",
                "snobol",
                "swift",
                "typescript",
                "visualbasic",
                "zig"
            ]
        },
        "Source": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "string"
                        },
                        "url": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "name"
                    ]
                }
            ]
        },
        "Type": {
            "enum": [
                "pass-fail",
                "scoring",
                "multi-pass",
                "interactive",
                "submit-answer"
            ]
        },
        "Valid": {
            "type": "string"
        }
    },
    "type": "object",
    "properties": {
        "keywords": {
            "description": "Keywords describing this problem, such as \"graph\", \"dynamic programming\", or \"greedy\".\nThese are not standardized and are only for informational purposes.",
            "allOf": [
                {
                    "type": "array",
                    "description": "Keywords describing this problem, such as \"graph\", \"dynamic programming\", or \"greedy\".\nThese are not standardized and are only for informational purposes.",
                    "items": {
                        "type": "string"
                    }
                },
                {
                    "type": "array",
                    "description": "Keywords describing this problem, such as \"graph\", \"dynamic programming\", or \"greedy\".\nThese are not standardized and are only for informational purposes.",
                    "items": {
                        "type": "string"
                    }
                }
            ]
        },
        "limits": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
                "time_limit": {
                    "type": "number",
                    "anyOf": [
                        {
                            "type": "number"
                        },
                        {
                            "type": "integer"
                        }
                    ],
                    "exclusiveMinimum": 0
                },
                "time_multipliers": {
                    "type": "object",
                    "properties": {
                        "ac_to_time_limit": {
                            "type": "number"
                        },
                        "time_limit_to_tle": {
                            "type": "number"
                        }
                    }
                },
                "time_resolution": {
                    "type": "number"
                }
            }
        },
        "name": {
            "description": "The name of the problem in each language for which a problem statement exists."
        },
        "problem_format_version": {
            "enum": [
                "2025-09",
                "legacy"
            ]
        },
        "type": true,
        "uuid": {
            "description": "A universally unique identifier for this problem, such as `acde070d-8c4c-4f0d-9d8a-162843c10333`.",
            "$ref": "#/$defs/Valid"
        }
    },
    "anyOf": [
        {
            "type": "object",
            "properties": {
                "allow_file_writing": {
                    "anyOf": [
                        {
                            "const": false
                        },
                        {
                            "const": true
                        }
                    ]
                },
                "constants": {
                    "type": "object",
                    "patternProperties": {
                        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
                            "anyOf": [
                                {
                                    "type": "integer"
                                },
                                {
                                    "type": "number"
                                },
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "object",
                                    "additionalProperties": true,
                                    "properties": {
                                        "value": {
                                            "anyOf": [
                                                {
                                                    "type": "integer"
                                                },
                                                {
                                                    "type": "number"
                                                },
                                                {
                                                    "type": "string"
                                                }
                                            ]
                                        }
                                    },
                                    "required": [
                                        "value"
                                    ]
                                }
                            ]
                        }
                    }
                },
                "credits": {
                    "description": "The persons who should get credit for this problem.",
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "object",
                            "properties": {
                                "acknowledgements": {
                                    "description": "Acknowledgements or special to persons who helped with this problem.",
                                    "$ref": "#/$defs/Persons"
                                },
                                "authors": {
                                    "description": "The author(s) of this problem.",
                                    "$ref": "#/$defs/Persons"
                                },
                                "contributors": {
                                    "description": "The people who developed the problem package, such as the statement, validators, and test data.",
                                    "$ref": "#/$defs/Persons"
                                },
                                "packagers": {
                                    "description": "The people who created the problem package out of an existing problem description.",
                                    "$ref": "#/$defs/Persons"
                                },
                                "testers": {
                                    "description": "The people who tested the problem package, for example, by providing a solution and reviewing the statement.",
                                    "$ref": "#/$defs/Persons"
                                },
                                "translators": {
                                    "type": "object",
                                    "description": "The people who translated the statement to other languages.",
                                    "patternProperties": {
                                        "^[a-z]{2,3}(-[A-Z]{2})?$": {
                                            "$ref": "#/$defs/Persons"
                                        }
                                    }
                                }
                            },
                            "required": [
                                "authors"
                            ]
                        }
                    ]
                },
                "embargo_until": {
                    "anyOf": [
                        {
                            "type": "string",
                            "format": "date"
                        },
                        {
                            "type": "string"
                        }
                    ]
                },
                "languages": {
                    "anyOf": [
                        {
                            "const": "all"
                        },
                        {
                            "type": "array",
                            "items": {
                                "$ref": "#/$defs/ProgrammingLanguage"
                            },
                            "prefixItems": [
                                {
                                    "$ref": "#/$defs/ProgrammingLanguage"
                                }
                            ],
                            "minItems": 1
                        }
                    ]
                },
                "license": {
                    "description": "The license under which this problem may be used.",
                    "anyOf": [
                        {
                            "const": "unknown"
                        },
                        {
                            "const": "public domain"
                        },
                        {
                            "const": "cc0"
                        },
                        {
                            "const": "cc by"
                        },
                        {
                            "const": "cc by-sa"
                        },
                        {
                            "const": "educational"
                        },
                        {
                            "const": "permission"
                        }
                    ]
                },
                "name": {
                    "description": "The name field is a map of language codes to problem names.\nThe set of languages for which name is given must exactly match the set of languages for which a problem statement exists.",
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "object",
                            "patternProperties": {
                                "^[a-z]{2,3}(-[A-Z]{2})?$": {
                                    "type": "string"
                                }
                            }
                        }
                    ]
                },
                "problem_format_version": {
                    "const": "2025-09"
                },
                "rights_owner": {
                    "description": "The person(s) owning the rights to this problem.",
                    "$ref": "#/$defs/Persons"
                },
                "source": {
                    "description": "The source(s) of this problem, such as `Northwestern Europe Regional Contest (NWERC) 2005`.",
                    "anyOf": [
                        {
                            "$ref": "#/$defs/Source"
                        },
                        {
                            "type": "array",
                            "items": {
                                "$ref": "#/$defs/Source"
                            },
                            "prefixItems": [
                                {
                                    "$ref": "#/$defs/Source"
                                }
                            ],
                            "minItems": 1
                        }
                    ]
                },
                "type": {
                    "description": "The type of this problem, such as \"pass-fail\" or [\"scoring\", \"interactive\"]",
                    "anyOf": [
                        {
                            "const": "pass-fail"
                        },
                        {
                            "$ref": "#/$defs/Type"
                        },
                        {
                            "type": "array",
                            "items": {
                                "$ref": "#/$defs/Type"
                            },
                            "prefixItems": [
                                {
                                    "$ref": "#/$defs/Type"
                                }
                            ],
                            "minItems": 1
                        }
                    ]
                },
                "uuid": true,
                "version": {
                    "type": "string",
                    "description": "The version of this problem, as it undergoes (slight) changes possibly during development or deployment.\nThis can be used to check whether a problem uploaded to a contest system needs to be updated since it does not contain the latest fixes."
                }
            },
            "required": [
                "name",
                "uuid"
            ]
        },
        {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "problem_format_version": {
                    "const": "legacy"
                }
            },
            "required": [
                "name"
            ]
        }
    ],
    "required": [
        "name",
        "problem_format_version"
    ]
}
