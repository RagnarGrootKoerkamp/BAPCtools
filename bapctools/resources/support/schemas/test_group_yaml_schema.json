{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$defs": {
        "absolute_path": {
            "type": "string",
            "description": "A path rooted at the package root, such as \"/data/secret/huge\" or \"/submissions/accepted/x.cpp\".",
            "$ref": "#/$defs/path",
            "pattern": "^/"
        },
        "command": {
            "type": "string",
            "not": {
                "pattern": "\\{seed.*\\{seed"
            }
        },
        "data_dict": {
            "type": "object",
            "additionalProperties": false,
            "patternProperties": {
                "^[a-zA-Z0-9_][a-zA-Z0-9_.-]{0,254}$": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/test_group"
                        },
                        {
                            "$ref": "#/$defs/test_case"
                        }
                    ]
                }
            }
        },
        "data_list": {
            "type": "object",
            "additionalProperties": true
        },
        "path": {
            "type": "string",
            "description": "Paths are /-separated sequences of names, optionally rooted at the package root (a leading\n/). #path is the general grammar; #relative_path and #absolute_path specialize it to one or\nthe other for contexts where only one is legal.",
            "pattern": "^/?([a-zA-Z0-9_][a-zA-Z0-9_.-]{0,254}/)*[a-zA-Z0-9_][a-zA-Z0-9_.-]{0,254}$"
        },
        "relative_path": {
            "type": "string",
            "description": "A path relative to the package root, such as \"data/secret/huge\" or \"submissions/accepted/x.cpp\".",
            "$ref": "#/$defs/path",
            "not": {
                "pattern": "^/"
            }
        },
        "test_case": {
            "anyOf": [
                {
                    "$ref": "#/$defs/command"
                },
                {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "ans": {
                            "type": "string",
                            "description": "Generate an .ans-file whose contents are this string literal."
                        },
                        "ans.download": {
                            "type": [
                                "string",
                                "object"
                            ]
                        },
                        "ans.statement": {
                            "type": [
                                "string",
                                "object"
                            ]
                        },
                        "copy": {
                            "description": "Create this test case by copying files from the given path.\nThe path is relative to \"/generators/\" and ends in a test case name,\nsuch as \"manual/samples/3\".",
                            "$ref": "#/$defs/relative_path"
                        },
                        "count": {
                            "allOf": [
                                {
                                    "description": "The number of test cases created by running this generator.\nIf generate is used and {seed} or {seed:(0-9)+} is present all Generator objects will use a different seed.\nThe arguments of generate may contain {count} to refer to the index of this generator invocation.\nBy default, the indices generated by \"count: 3\" are [1,2,3]. Specify other indices as a list,\nusing \"count: [1,2,3]\" or as a (Rust-like, endpoint-inclusive) range expression like \"count: 1..=3\".",
                                    "anyOf": [
                                        {
                                            "type": "integer"
                                        },
                                        {
                                            "type": "array",
                                            "items": {
                                                "type": "integer"
                                            }
                                        },
                                        {
                                            "type": "string"
                                        }
                                    ]
                                },
                                {
                                    "type": "array",
                                    "description": "If count is a list of integers, use that directly",
                                    "items": {
                                        "type": "integer"
                                    },
                                    "uniqueItems": true
                                }
                            ]
                        },
                        "generate": {
                            "description": "Create this testcase by invoking a generator, like \"generate: gen_tree -n 5\"",
                            "$ref": "#/$defs/command"
                        },
                        "in": {
                            "type": "string",
                            "description": "Generate an .in-file whose contents are this string literal."
                        },
                        "in.download": {
                            "type": [
                                "string",
                                "object"
                            ]
                        },
                        "in.statement": {
                            "type": [
                                "string",
                                "object"
                            ]
                        },
                        "interaction": {
                            "type": "string",
                            "pattern": "^([<>][^\\n]*\\n|---\\n)+$"
                        },
                        "match": {
                            "description": "Check that the generated testcase matches the given regex pattern(s).",
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                },
                                {
                                    "type": "object",
                                    "additionalProperties": false,
                                    "properties": {
                                        "ans": {
                                            "anyOf": [
                                                {
                                                    "type": "string"
                                                },
                                                {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "string"
                                                    }
                                                }
                                            ]
                                        },
                                        "in": {
                                            "anyOf": [
                                                {
                                                    "type": "string"
                                                },
                                                {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "string"
                                                    }
                                                }
                                            ]
                                        }
                                    }
                                }
                            ]
                        },
                        "out": {
                            "type": "string",
                            "description": "Generate an .out-file whose contents are this string literal."
                        },
                        "random_salt": {
                            "type": "string",
                            "description": "A string that is be prepended to each command before computing its {seed}.\nMay be used to regenerate all random cases and to prevent predictable seeds."
                        },
                        "retries": {
                            "type": "integer",
                            "description": "The maximum number of invocation that will be tried if the generator fails.\nEach generator invocation uses a different value for {seed}."
                        },
                        "solution": {
                            "description": "A model solution used for generating answer files, like \"/submissions/accepted/intended.py\"",
                            "$ref": "#/$defs/absolute_path"
                        },
                        "yaml": {
                            "$ref": "#/$defs/test_case_configuration"
                        }
                    },
                    "required": [
                        "count"
                    ]
                }
            ]
        },
        "test_case_configuration": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "description": {
                    "type": "string"
                },
                "hint": {
                    "type": "string"
                }
            },
            "$ref": "#/$defs/test_case_or_group_configuration"
        },
        "test_case_or_group_configuration": {
            "type": "object",
            "description": "Test data configuration",
            "additionalProperties": false,
            "properties": {
                "answer_validator_args": {
                    "anyOf": [
                        {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        {
                            "type": "object",
                            "additionalProperties": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    ]
                },
                "args": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "full_feedback": {
                    "type": "boolean"
                },
                "input_validator_args": {
                    "anyOf": [
                        {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        {
                            "type": "object",
                            "additionalProperties": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    ]
                },
                "input_visualizer_args": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "output_validator_args": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "output_visualizer_args": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "test_data_group": {
            "type": "string",
            "description": "A named subdivision of `secret`, nested to any depth, such as \"secret/group1\" or\n\"secret/group1/sub\". Never bare \"secret\" itself -- secret may only depend on sample\n(via the separate \"sample\" literal in require_pass below), never on itself.",
            "pattern": "^secret(/[a-zA-Z0-9_][a-zA-Z0-9_.-]{0,254})+$"
        },
        "test_group": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "data": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/data_dict"
                        },
                        {
                            "type": "array",
                            "items": {
                                "$ref": "#/$defs/data_list"
                            }
                        }
                    ]
                },
                "include": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/path"
                    }
                },
                "random_salt": {
                    "type": "string",
                    "description": "A string that is be prepended to each command before computing its {seed}.\nMay be used to regenerate all random cases and to prevent predictable seeds."
                },
                "retries": {
                    "type": "integer",
                    "description": "The maximum number of invocation that will be tried if the generator fails.\nEach generator invocation uses a different value for {seed}."
                },
                "solution": {
                    "description": "A model solution used for generating answer files, like \"/submissions/accepted/intended.py\"",
                    "$ref": "#/$defs/absolute_path"
                },
                "test_group.yaml": {
                    "$ref": "#/$defs/test_group_configuration"
                }
            }
        },
        "test_group_configuration": {
            "type": "object",
            "description": "Configuration for test_group.yaml (2025-09 format only -- legacy uses testdata.yaml,\n#testdata_configuration, with an unrelated set of keys).",
            "additionalProperties": false,
            "properties": {
                "max_score": {
                    "anyOf": [
                        {
                            "allOf": [
                                {
                                    "type": "number"
                                },
                                {
                                    "type": "integer",
                                    "minimum": 0
                                }
                            ]
                        },
                        {
                            "const": "unbounded"
                        }
                    ]
                },
                "require_pass": {
                    "anyOf": [
                        {
                            "const": "sample"
                        },
                        {
                            "$ref": "#/$defs/test_data_group"
                        },
                        {
                            "type": "array",
                            "items": {
                                "anyOf": [
                                    {
                                        "const": "sample"
                                    },
                                    {
                                        "$ref": "#/$defs/test_data_group"
                                    }
                                ]
                            }
                        }
                    ]
                },
                "score_aggregation": {
                    "enum": [
                        "pass-fail",
                        "sum",
                        "min"
                    ]
                },
                "static_validation_score": {
                    "anyOf": [
                        {
                            "allOf": [
                                {
                                    "type": "number"
                                },
                                {
                                    "type": "integer",
                                    "minimum": 0
                                }
                            ]
                        },
                        {
                            "const": "pass-fail"
                        }
                    ]
                }
            },
            "$ref": "#/$defs/test_case_or_group_configuration"
        }
    },
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "data": {
            "anyOf": [
                {
                    "$ref": "#/$defs/data_dict"
                },
                {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/data_list"
                    }
                }
            ]
        },
        "include": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/path"
            }
        },
        "random_salt": {
            "type": "string",
            "description": "A string that is be prepended to each command before computing its {seed}.\nMay be used to regenerate all random cases and to prevent predictable seeds."
        },
        "retries": {
            "type": "integer",
            "description": "The maximum number of invocation that will be tried if the generator fails.\nEach generator invocation uses a different value for {seed}."
        },
        "solution": {
            "description": "A model solution used for generating answer files, like \"/submissions/accepted/intended.py\"",
            "$ref": "#/$defs/absolute_path"
        },
        "test_group.yaml": {
            "$ref": "#/$defs/test_group_configuration"
        }
    }
}
